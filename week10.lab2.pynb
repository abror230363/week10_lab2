   ],
   "source": [
    "\n",
    "import os\n",
    "\n",
    "base = \"/Users/230363/Documents/Mask-Generation\"\n",
    "\n",
    "print(\"Exists:\", os.path.exists(base))\n",
    "print(\"Contents:\")\n",
    "print(os.listdir(base))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "1b2192e9-3ae6-4081-b234-301d8587972c",
