    }
   ],
   "source": [
    "\n",
    "import os\n",
    "\n",
    "image_root = \"/Users/230363/Documents/Mask-Generation/images/train\"\n",
    "image_list = []\n",
    "\n",
    "for root, dirs, files in os.walk(image_root):\n",
    "    for file in files:\n",
    "        if file.lower().endswith(\".jpg\"):\n",
    "            image_list.append(os.path.join(root, file))\n",
    "\n",
    "\n",
    "print(\"Number of images:\", len(image_list))\n",
    "if len(image_list) > 0:\n",
    "    print(\"First image path:\", image_list[0])\n",
    "else:\n",
    "    print(\"No images found. Check the folder path again.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "e77f6e4f-7287-47b5-a203-0c313acb350e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Image shape: (481, 321)\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "img = Image.open(image_list[0]).convert(\"L\")\n",
    "img_array = np.array(img)\n",
    "\n",
    "print(\"Image shape:\", img_array.shape)\n",
    "\n",
    "plt.imshow(img_array, cmap=\"gray\")\n",
    "plt.title(\"Grayscale Image\")\n",
    "plt.axis(\"off\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "978aed34-4dff-4d15-8ba3-e1aaa60bb61e",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "T = 120   \n",
    "\n",
    "mask = (img_array > T).astype(np.uint8)\n",
    "\n",
    "plt.imshow(mask, cmap=\"gray\")\n",
    "plt.title(\"Binary Mask using Threshold\")\n",
    "plt.axis(\"off\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "1849cc9c-ece1-447a-a7fa-7631fa1dc014",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "Gx = sobel(img_array, axis=1)   \n",
    "Gy = sobel(img_array, axis=0)   \n",
    "\n",
    "gradient_magnitude = np.sqrt(Gx**2 + Gy**2)\n",
    "\n",
    "plt.imshow(gradient_magnitude, cmap=\"gray\")\n",
    "plt.title(\"Gradient Magnitude\")\n",
    "plt.axis(\"off\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "6be2b6e2-0357-483c-bab9-1da342e98d90",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "Te = 80  \n",
    "\n",
    "edges = (gradient_magnitude > Te).astype(np.uint8)\n",
    "\n",
    "plt.imshow(edges, cmap=\"gray\")\n",
    "plt.title(\"Edge Detection Result\")\n",
    "plt.axis(\"off\")\n",
    "plt.show()\n",
    "     "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "b4ed43c1-7ed4-4347-bdab-ca676f19b473",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1200x400 with 4 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "plt.figure(figsize=(12,4))\n",
    "\n",
    "plt.subplot(1,4,1)\n",
    "plt.imshow(img_array, cmap=\"gray\")\n",
    "plt.title(\"Original\")\n",
    "plt.axis(\"off\")\n",
    "\n",
    "plt.subplot(1,4,2)\n",
    "plt.imshow(mask, cmap=\"gray\")\n",
    "plt.title(\"Mask\")\n",
    "plt.axis(\"off\")\n",
    "\n",
    "plt.subplot(1,4,3)\n",
    "plt.imshow(gradient_magnitude, cmap=\"gray\")\n",
    "plt.title(\"Gradient\")\n",
    "plt.axis(\"off\")\n",
    "\n",
    "plt.subplot(1,4,4)\n",
    "plt.imshow(edges, cmap=\"gray\")\n",
    "plt.title(\"Edges\")\n",
    "plt.axis(\"off\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "31fd4eb6-9345-406b-ab3b-5270dbf5fde9",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total images found: 200\n",
      "Example: /Users/230363/Documents/Mask-Generation/images/train/100075.jpg\n"
     ]
    }
   ],
   "source": [
    "image_list = []\n",
    "\n",
    "for root, dirs, files in os.walk(image_root):\n",
    "    for file in files:\n",
    "        if file.lower().endswith(\".jpg\"):\n",
    "            image_list.append(os.path.join(root, file))\n",
    "\n",
    "image_list = sorted(image_list)\n",
    "\n",
    "print(\"Total images found:\", len(image_list))\n",
    "print(\"Example:\", image_list[0])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "75bc0cf1-c094-49b6-84e2-1fdf861d11b4",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Masks will be saved in: /Users/230363/Documents/Mask-Generation/images/train/generated_masks_New\n"
     ]
    }
   ],
   "source": [
    "mask_folder = os.path.join(image_root, \"generated_masks_New\")\n",
    "os.makedirs(mask_folder, exist_ok=True)\n",
    "\n",
    "print(\"Masks will be saved in:\", mask_folder)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "c8d5598a-18b2-431b-a0c6-86b966c808f1",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Using threshold: 120\n"
     ]
    }
   ],
   "source": [
    "T = 120\n",
    "print(\"Using threshold:\", T)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "533c0311-1749-4090-bb5f-3e3b329572d3",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "All masks generated successfully.\n"
     ]
    }
   ],
   "source": [
    "for img_path in image_list:\n",
    "  \n",
    "    img = Image.open(img_path).convert(\"L\")\n",
    "    img_array = np.array(img)\n",
    "\n",
    "    mask = (img_array > T).astype(np.uint8) * 255\n",
    "\n",
    "    img_name = os.path.basename(img_path)\n",
    "    name_without_ext = os.path.splitext(img_name)[0]\n",
    "    save_path = os.path.join(mask_folder, name_without_ext + \"_mask.png\")\n",
    "\n",
    "    Image.fromarray(mask).save(save_path)\n",
    "\n",
    "print(\"All masks generated successfully.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "5af947df-bd9a-4fe5-bcea-3fda03f2cb6c",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1000x400 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "sample_img_path = image_list[100]\n",
    "\n",
    "img = Image.open(sample_img_path).convert(\"L\")\n",
    "img_array = np.array(img)\n",
    "\n",
    "mask_path = os.path.join(\n",
    "    mask_folder,\n",
    "    os.path.splitext(os.path.basename(sample_img_path))[0] + \"_mask.png\"\n",
    ")\n",
    "mask = np.array(Image.open(mask_path))\n",
    "\n",
    "plt.figure(figsize=(10,4))\n",
    "\n",
    "plt.subplot(1,2,1)\n",
    "plt.imshow(img_array, cmap=\"gray\")\n",
    "plt.title(\"Original Image\")\n",
    "plt.axis(\"off\")\n",
    "\n",
    "plt.subplot(1,2,2)\n",
    "plt.imshow(mask, cmap=\"gray\")\n",
    "plt.title(\"Generated Mask\")\n",
    "plt.axis(\"off\")\n",
    "\n",
    "plt.show()"
   ]
  },
