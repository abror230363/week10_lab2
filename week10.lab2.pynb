    "import os\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from PIL import Image\n",
    "from scipy.ndimage import sobel"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "7a66d8b5-c3f0-4cb6-b6a0-48098cd51007",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
